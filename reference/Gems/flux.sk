						else if {-KinOvMAINCOUNTER::%loop-player's uuid%} is 15:
							send "&7You have &b15 &cATTACK &7points. &7Your next hit will do &b1.5x damage." to loop-player

					
on damage:
	if {-KinOvMAIN::%attacker's uuid%} is true:
		if {-KinOvMAINCOUNTER::%attacker's uuid%} is between 3 and 6:
			cancel event
			damage victim by damage * 1.1
			knock victim (vector from attacker to victim) with strength 0.7
			set {-KinOvMAINCOUNTER::%attacker's uuid%} to 0
		if {-KinOvMAINCOUNTER::%attacker's uuid%} is between 6 and 9:
			cancel event
			damage victim by damage * 1.2
			knock victim (vector from attacker to victim) with strength 0.7
			set {-KinOvMAINCOUNTER::%attacker's uuid%} to 0
		if {-KinOvMAINCOUNTER::%attacker's uuid%} is between 9 and 12:
			cancel event
			damage victim by damage * 1.3
			knock victim (vector from attacker to victim) with strength 0.7
			set {-KinOvMAINCOUNTER::%attacker's uuid%} to 0
		if {-KinOvMAINCOUNTER::%attacker's uuid%} is between 12 and 15:
			cancel event
			damage victim by damage * 1.4
			knock victim (vector from attacker to victim) with strength 0.7
			set {-KinOvMAINCOUNTER::%attacker's uuid%} to 0
		if {-KinOvMAINCOUNTER::%attacker's uuid%} is between 15 and 15:
			cancel event
			damage victim by damage * 1.5
			knock victim (vector from attacker to victim) with strength 0.7
			set {-KinOvMAINCOUNTER::%attacker's uuid%} to 0

on break:
	if {-KinOvALT::%player's uuid%} is true:
		loop all players:
			if player is not loop-player:
				if {-KinOvMAIN::%loop-player's uuid%} is true:
					add 1 to {fluxBroken.%loop-player's uuid%}
					if {fluxBroken.%loop-player's uuid%} is 5:
						send "&7You have &b1 &eMINING &7point, giving you Haste level &b1 &7for &b20s&7." to loop-player
						apply haste 1 without particles to loop-player for 20 seconds replacing the existing effect
					if {fluxBroken.%loop-player's uuid%} is 10:
						send "&7You have &b2 &eMINING &7points, giving you Haste level &b2 &7for &b40s&7." to loop-player
						apply haste 2 without particles to loop-player for 40 seconds replacing the existing effect
					if {fluxBroken.%loop-player's uuid%} is 15:
						send "&7You have &b3 &eMINING &7points, giving you Haste level &b3 &7for &b60s&7." to loop-player
						apply haste 3 without particles to loop-player for 60 seconds replacing the existing effect
					if {fluxBroken.%loop-player's uuid%} is 20:
						send "&7You have &b4 &eMINING &7points, giving you Haste level &b4 &7for &b80s&7." to loop-player
						apply haste 4 without particles to loop-player for 80 seconds replacing the existing effect
					if {fluxBroken.%loop-player's uuid%} is 25:
						send "&7You have &b5 &eMINING &7points, giving you Haste level &b5 &7for &b100s&7." to loop-player
						apply haste 5 without particles to loop-player for 100 seconds replacing the existing effect
 
 
on right click on entity:
	if isDisabled(player) is not true:
		if getGem(player's held item) is "flux":
			if getTier(player's held item) is 2:
				if canUsePower("KineticOverdrive::%uuid of player%") is true:
					if getEnergy(player's held item) is 0:
						stop
					if getEnergy(player's held item) is 1:
						blissSetcooldown("KineticOverdrive::%uuid of player%", toMilliseconds(2, 40), player)
						set {_num} to 0
					if getEnergy(player's held item) is 2:
						blissSetcooldown("KineticOverdrive::%uuid of player%", toMilliseconds(2, 30), player)
						set {_num} to 0.5
					if getEnergy(player's held item) is 3:
						blissSetcooldown("KineticOverdrive::%uuid of player%", toMilliseconds(2, 20), player)
						set {_num} to 0.5
					if getEnergy(player's held item) is 4:
						blissSetcooldown("KineticOverdrive::%uuid of player%", toMilliseconds(2, 10), player)
						set {_num} to 1.5
					if getEnergy(player's held item) > 4:
						blissSetcooldown("KineticOverdrive::%uuid of player%", toMilliseconds(2, 0), player)
						set {_num} to 1.5
					set {_loc} to location of player
					send "<#03eaff>🔮 You have activated Kinetic Overdrive!" to player
					set {-KinOvMAIN::%player's uuid%} to true
					set {-KinOvALT::%target entity of player's uuid%} to true
					set {-KinOvMAINCOUNTER::%player's uuid%} to 0
					send "<#03eaff>🔮 You have been affected with %player%'s Kinetic Overdrive! &7Radius %{_num}%" to target entity of player
					set {_loc} to location of target entity of player
					loop 5 times:
						FluxCircleReal({_num}, {_loc})
						add 0.5 to {_num}
						wait 1 tick
					FluxCircleRealLast({_num}, {_loc})
					set {_p} to player
					loop all players within {_num} blocks of player:
						if loop-player is not {_p}:
							if IsTrusted(player, loop-player) is false:
								set {-KinOvALT::%loop-player's uuid%} to true
								send "<#03eaff>🔮 You have been affected with %player%'s Kinetic Overdrive! &7Radius %{_num}%" to loop-player
								wait 30 seconds
								set {-KinOvALT::%loop-player's uuid%} to false
					wait 30 seconds
					set {-KinOvALT::%target entity of player's uuid%} to false
					set {-KinOvMAIN::%player's uuid%} to false
					delete {-KinOvMAINCOUNTER::%player's uuid%}
					remove haste from the player
					set {fluxBroken.%player's uuid%} to 0			

				else:
					set {_bb} to getActionBarCooldown("KineticOverdrive::%uuid of player%")							
					send "<#03eaff>🔮 <##FF686F>Your Kinetic Energy is on cooldown for <##0EC912>%{_bb}%" to player



function FluxCircleReal(s: number, pl: location):
	loop 360 times:
		set {_v} to spherical vector with radius {_s}, yaw loop-value and pitch 0
		make 1 of dust using dustOption(rgb(94, 215, 255), 0.9) at {_pl} ~ {_v} with extra 0 with force
		draw 1 of happy villager at {_pl} ~ {_v} with extra 0 with force

function FluxCircleRealLast(s: number, pl: location):
	loop 10 times:
		loop 360 times:
			set {_v} to spherical vector with radius {_s}, yaw loop-value-2 and pitch 0
			make 1 of dust using dustOption(rgb(94, 215, 255), 0.9) at {_pl} ~ {_v} with extra 0 with force
			draw 1 of happy villager at {_pl} ~ {_v} with extra 0 with force
		wait 0.3 seconds


on damage:
	if all:
		{-Options::FluxGroundForNonPlayers} is false
		victim is not a player
	then:
		stop
	if isDisabled(attacker) is not true:
		if getGem(attacker's held item) is "flux":
			if getTier(attacker's held item) is 2:
				if canUsePower("EnergyBeam::%uuid of attacker%") is true:
					set {_uuid} to uuid of attacker
					if attacker is not victim:
						if IsTrusted(attacker, victim) is true:
							send "<##FFD773>🔮 &fYou cannot cast negative powers on allies!" to attacker
						else:
							if victim is invisible:
								send "<#03eaff>🔮 You have used Ground on <##0EC912>&k???" to attacker
							else:
								send "<#03eaff>🔮 You have used Ground on <##0EC912>%victim.getName()%" to attacker

							if attacker is invisible:
								send "<#03eaff>🔮 You have been affected with Ground by <##0EC912>&b&k???" to victim
							else:
								send "<#03eaff>🔮 You have been affected with Ground by <##0EC912>&b%attacker.getName()%" to victim
							if getEnergy(attacker's held item) is 1:
								blissSetcooldown("EnergyBeam::%uuid of attacker%", toMilliseconds(0, 50), attacker)
							if getEnergy(attacker's held item) is 2:
								blissSetcooldown("EnergyBeam::%uuid of attacker%", toMilliseconds(0, 45), attacker)
							if getEnergy(attacker's held item) is 3:
								blissSetcooldown("EnergyBeam::%uuid of attacker%", toMilliseconds(0, 40), attacker)
							if getEnergy(attacker's held item) is 4:
								blissSetcooldown("EnergyBeam::%uuid of attacker%", toMilliseconds(0, 35), attacker)
							if getEnergy(attacker's held item) > 4:
								blissSetcooldown("EnergyBeam::%uuid of attacker%", toMilliseconds(0, 30), attacker)
							wait 5 ticks
							if {fluxKinetic::%attacker's uuid%} is more than or equal to 100:
								GroundShuffle(victim)
							set {-fluxKiller} to attacker
							Stun(victim, 4)
							set {_d} to {fluxKinetic::%attacker's uuid%} percent of victim's health
							set {_d1} to {_d} / 2
							realDamage(victim, {_d1})
							if {-Options::FluxGroundDamage} is true:
								ticklessDamage(victim)
							set {-ground::%victim's uuid%} to true
							loop all entities within 3 blocks of victim:
								loop-entity is not attacker
								loop-entity is not victim
								IsTrusted(attacker, loop-entity) is not true
								groundEntity(loop-entity, attacker)
							wait 1 second
							delete {-fluxKiller}
							delete {-ground::%victim's uuid%}
							set {fluxKinetic::%attacker's uuid%} to 0
							delete {-fluxLine::%victim's uuid%}

				else:
					set {_message} to getActionBarCooldown("EnergyBeam::%uuid of attacker%")
					send "<#03eaff>🔮 <##FF686F>Your Ground is on cooldown for <##0EC912>%{_message}%" to attacker
	
function groundLine(attacker: entity, victim: entity):
	set {_distance} to distance between {_attacker} and {_victim}
	if {_distance} > 20:
		set {_distance} to 20

	set {_loc} to location 0.8 blocks above {_attacker}
	set {_v} to vector from {_loc} to location 0.8 blocks above {_victim}
	set vector length of {_v} to 0.1
	loop {_distance} / 0.1 times:
		make 3 of dust using dustOption(rgb(94, 215, 255), 1) at {_loc}
		make 1 of smoke at {_loc} with extra 0
		set {_loc} to {_loc} ~ {_v}
	


function groundEntity(entity: entity, caster: player):
	set {-ground::%{_entity}'s uuid%} to true
	Stun({_entity}, 3)
	ticklessDamage({_entity})
	wait 1 second
	delete {-ground::%{_entity}'s uuid%}
	set {fluxKinetic::%{_caster}'s uuid%} to 0

function Stun(entity: entity, n: number):
	set {_loc} to location of {_entity}
	loop ({_n} * 20) times:
		if any:
			abs(x coord of {_entity} - x coord of {_loc}) > 0.005
			abs(y coord of {_entity} - y coord of {_loc}) > 0.005
			abs(z coord of {_entity} - z coord of {_loc}) > 0.005
		then:
			set yaw of {_loc} to yaw of {_entity}
			set pitch of {_loc} to pitch of {_entity}
			teleport {_entity} to {_loc}
		wait 1 tick


function ticklessDamage(p: entity):
	#loop 1 times: #this is how it is in real bliss gng
	set invulnerability ticks of {_p} to 0
	damage {_p} by 0.001
	wait 1 tick


on join:
	if {fluxKinetic::%player's uuid%} is not set:
		set {fluxKinetic::%player's uuid%} to 0

on death of player:
	if {-damaged::%victim's uuid%} is true:
		if {-fluxKiller} is invisible:
			set death message to "%victim% was obliterated by &k???"
		else:
			set death message to "%victim% was obliterated by %{-fluxKiller}%"

on death of player:
	if {-ground::%victim's uuid%} is true:
		if {-fluxKiller} is invisible:
			set death message to "%victim% experienced high voltage from &k???"
		else:
			set death message to "%victim% experienced high voltage from %{-fluxKiller}%"

function realDamage(p: entity, a: number):
	damage {_p} by 0.001
	if {_p}'s health < {_num}:
		if any:
			{_p}'s held item is a totem of undying
			{_p}'s offhand item is a totem of undying
		then:
			damage {_p} by 151515
		else:
			set {_p}'s health to {_p}'s health - {_a}
			add {_p} to {-dontdmgagain::*}
	else:
		set {_p}'s health to {_p}'s health - {_a}

command /reset-charge:
	permission: op
	trigger:
		loop all offlineplayers:
			set {fluxKinetic::%loop-offlineplayer's uuid%} to 0


function FluxCircle(s: number, p: location):
	set {_pl} to location of {_p}
	loop all players:
		if {particlelvl::%loop-player's uuid%} is "default":
			
			set {_spacing} to 0.1
			set {_circumference} to 2 * pi * {_s} # Calculate the number of particles based on the spacing
			set {_numParticles} to floor({_circumference} / {_spacing}) # Spawn the exact number of particles needed

			loop {_numParticles} times:
				set {_angle} to loop-value-2 * 360 / {_numParticles}
				set {_v} to spherical vector with radius {_s}, yaw {_angle} and pitch 0
				
				make 1 of dust using dustOption(rgb(94, 215, 255), 1) at {_pl} ~ {_v} for loop-player
				draw 1 of smoke at {_pl} ~ {_v} with extra 0 with force for loop-player

		if {particlelvl::%loop-player's uuid%} is "less":

			set {_spacing} to 0.15
			set {_circumference} to 2 * pi * {_s}
			set {_numParticles} to floor({_circumference} / {_spacing})

			loop {_numParticles} times:
				set {_angle} to loop-value-2 * 360 / {_numParticles}
				set {_v} to spherical vector with radius {_s}, yaw {_angle} and pitch 0
				
				make 1 of dust using dustOption(rgb(94, 215, 255), 1) at {_pl} ~ {_v} for loop-player
		if {particlelvl::%loop-player's uuid%} is "none":

			set {_spacing} to 0.5
			set {_circumference} to 2 * pi * {_s}
			set {_numParticles} to floor({_circumference} / {_spacing})

			loop {_numParticles} times:
				set {_angle} to loop-value-2 * 360 / {_numParticles}
				set {_v} to spherical vector with radius {_s}, yaw {_angle} and pitch 0
				
				make 1 of dust using dustOption(rgb(94, 215, 255), 1) at {_pl} ~ {_v} for loop-player


function FluxCirclelast(s: number, p: location):
	set {_pl} to location of {_p}
	loop 7 times:
		FluxCircle({_s}, {_pl})
		wait 0.3 seconds

function FluxCircleEXP(s: number, p: player):
	set {_pl} to location of {_p}
	set {_step} to 3 # Set a larger step value here
	set {_iterations} to 360 * {_s} / {_step}
	loop {_iterations} times:
		set {_angle} to loop-value * {_step}
		set {_v} to spherical vector radius {_s}, yaw {_angle}, pitch (0) # Pitch is set to 0 to make it around the {_p}
		draw 1 of happy_villager at {_pl} ~ {_v} with extra 0.000000001 with force


on damage:
	if getGem(victim's offhand item) is "flux":
		set {_finaldmg} to final damage / 3
		add {_finaldmg} to {damage::%victim's uuid%}
		set {timesHit::%victim's uuid%} to 0	
		wait 15 seconds
		remove {_finaldmg} from {damage::%victim's uuid%}



function GroundShuffle(player: player):

	set {_i} to random number between 1 and 9
	loop {_i} times:
		set {_slot.%loop-number%} to slot (loop-number - 1) of {_player}'s inventory

		add {_slot.%loop-number%} to {_shuffle::*}

	set {_shuffle::*} to shuffled {_shuffle::*}

	loop {_i} times:
		set slot (loop-number - 1) of {_player}'s inventory to {_shuffle::%loop-number%}