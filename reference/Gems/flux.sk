						else:
							set {_message} to getCooldownSeconds("KineticBurst::%uuid of player%")
							send "<#03eaff>🔮 <##FF686F> Kinetic Burst is on cooldown for <##0EC912>%{_message}%s" to player

	   
on damage:
	if attacker is set:
