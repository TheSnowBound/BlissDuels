left click:
	if isDisabled(player) is not true:
		if getGem(player's held item) is "life":
			if getTier(player's held item) is 2:
				if getEnergy(player's held item) is not 0:
					if canUsePower("HeartLock::%uuid of player%") is true:

						if getEnergy(player's held item) > 4:
							blissSetcooldown("HeartLock::%uuid of player%", toMilliseconds(2, 0), player)
							set {_num} to 3
						else if getEnergy(player's held item) is 4:
							blissSetcooldown("HeartLock::%uuid of player%", toMilliseconds(2, 10), player)
							set {_num} to 2.5
						else if getEnergy(player's held item) is 3:
							blissSetcooldown("HeartLock::%uuid of player%", toMilliseconds(2, 20), player)
							set {_num} to 2.5
						else if getEnergy(player's held item) is 2:
							blissSetcooldown("HeartLock::%uuid of player%", toMilliseconds(2, 30), player)
							set {_num} to 1.5
						else if getEnergy(player's held item) is 1:
							blissSetcooldown("HeartLock::%uuid of player%", toMilliseconds(2, 35), player)
							set {_num} to 1.5

						send "<##FE04B4>🔮 <##B8FFFB>You used &8💘<##FE04B4>Heart Drainer" to player
						set {_s} to 1
						set {_loc} to player's location
						loop {_num} + {_num} times:

							if loop-value is not {_num} + {_num}:
								LifeCircle({_s}, {_loc})
					
								add 0.5 to {_s}
								wait 1 tick

							else:
								LifeCirclelast({_s}, {_loc})

						set {_lifeholder} to player
						loop all entities within {_num} blocks of the player:
							if loop-entity is not {_lifeholder}:
								if IsTrusted(player, loop-entity) is false:
									send "<##FE04B4>🔮 &0💘<##B8FFFB>Your heart count has been reduced by &e15%% <##B8FFFB>for <##FE04B4>60 seconds <##B8FFFB>by <##FE04B4>%{_lifeholder}%" to loop-entity
									set {_h} to loop-entity's max health
									remove 2 from {_h}
									set loop-entity's max health to {_h}
									set {lifeblessed::%loop-entity's uuid%} to true
									wait 1 minute
									set loop-entity's max health to 10
									delete {lifeblessed::%loop-entity's uuid%}


			else:
				send "&f🔺 <##FD8988>You need tier 2 gem to cast this skill!" to player



on damage:
	if isDisabled(attacker) is not true:
		if getGem(attacker's held item) is "life":
			if getTier(attacker's held item) is 2:
				if canUsePower("HeartLock::%uuid of attacker%") is true:
					if getEnergy(attacker's held item) is not 0:
						if victim's max health > 3:
							if IsTrusted(attacker, victim) is not true:
								if getEnergy(attacker's held item) > 4:
									blissSetcooldown("HeartLock::%uuid of attacker%", toMilliseconds(2, 0), attacker)
								else if getEnergy(attacker's held item) is 4:
									blissSetcooldown("HeartLock::%uuid of attacker%", toMilliseconds(2, 10), attacker)
								else if getEnergy(attacker's held item) is 3:
									blissSetcooldown("HeartLock::%uuid of attacker%", toMilliseconds(2, 20), attacker)
								else if getEnergy(attacker's held item) is 2:
									blissSetcooldown("HeartLock::%uuid of attacker%", toMilliseconds(2, 30), attacker)
								else if getEnergy(attacker's held item) is 1:
									blissSetcooldown("HeartLock::%uuid of attacker%", toMilliseconds(2, 35), attacker)
								LifeLine(attacker, victim)
								set {-lifeLine::%victim's uuid%} to true

								if victim is not invisible:
									send "<##FE04B4>🔮 <##B8FFFB>You used &8💘<##FE04B4>Heart Lock <##B8FFFB>on <##FE04B4>%victim.getName()%" to attacker
								else:
									send "<##FE04B4>🔮 <##B8FFFB>You used &8💘<##FE04B4>Heart Lock <##B8FFFB>on <##FE04B4>&k???" to attacker
									
								if attacker is not invisible:
									send "<##FE04B4>🔮 <##B8FFFB>Your heart count has been locked for <##FE04B4>20 seconds <##B8FFFB>by <##FE04B4>%attacker%" to victim
								else:
									send "<##FE04B4>🔮 <##B8FFFB>Your heart count has been locked for <##FE04B4>20 seconds <##B8FFFB>by <##FE04B4>&k???" to victim
								set {HeartLocked::%victim's uuid%} to true
								set {_heal} to victim's health
								set victim's max health to {_heal}
								wait 20 seconds
								set victim's max health to 10
								set {HeartLocked::%victim's uuid%} to false
							else:
								send "<##FFD773>🔮 <##FFE4AB>You cannot cast negative skills on allies!" to attacker

			else:
				send "&f🔺 <##FD8988>You need tier 2 gem to cast this skill!" to attacker

on death:
	set victim's max health to 10
	execute console command "attribute %victim% minecraft:generic.attack_speed base set 4"

on drop:
	if event-item is dragon egg:
		if {lifeblessed::%player's uuid%} is not set:
			if {HeartLocked::%player's uuid%} is false:
				if {dragongames::%player's uuid%} is true:
					set {_h} to player's max health
					set {_li} to {hearts::%player's uuid%}
					add {_li} to {_h}
					set player's max health to {_h}
				else:
					set player's max health to 10

every 4 seconds:
	#done by smp remakers
	loop all players:
		if {lifeblessed::%loop-player's uuid%} is not set:
			if {HeartLocked::%loop-player's uuid%} is false:
				if loop-player has 1 of dragon egg:
					if {dragongames::%loop-player's uuid%} is true:
						set {_h} to 20
						set {_li} to {hearts::%loop-player's uuid%}
						add {_li} to {_h}
						set loop-player's max health to {_h}
						set loop-player's tab name to "&a%loop-player%"
					else:
						set loop-player's max health to 20
				else:
					if {dragongames::%loop-player's uuid%} is true:
						set loop-player's tab name to "&a%loop-player%"
						set {_h} to 10
						set {_li} to {hearts::%loop-player's uuid%}
						add {_li} to {_h}
						set loop-player's max health to {_h}
					else:
						set loop-player's max health to 10

on pickup:
	if event-item is dragon egg:
		if {lifeblessed::%player's uuid%} is not set:
			if {HeartLocked::%player's uuid%} is false:
				if {dragongames::%player's uuid%} is true:
					set {_h} to player's max health
					set {_li} to {hearts::%player's uuid%}
					add {_li} to {_h}
					set player's max health to {_h}
				else:
					set player's max health to 20


on join:
	delete {lifeblessed::%player's uuid%}
	if player has 1 of dragon egg:
		set player's max health to 20
		if {dragongames::%player's uuid%} is true:
			set {_h} to player's max health
			set {_li} to {hearts::%player's uuid%}
			add {_li} to {_h}
			set player's max health to {_h}
	else:
		set player's max health to 10
		if {dragongames::%player's uuid%} is true:
			set {_h} to player's max health
			set {_li} to {hearts::%player's uuid%}
			add {_li} to {_h}
			set player's max health to {_h}

on join:
	set {HeartLocked::%player's uuid%} to false
	execute console command "attribute %player% minecraft:generic.attack_speed base set 4"
	if {HeartLocked::%player's uuid%} is false:
		if player has 1 of dragon egg:
			set player's max health to 20
		else:
			set player's max health to 10




