	if isDisabled(player) is not true:
		if getGem(player's held item) is "life":
			if getTier(player's held item) is 2:
				if getEnergy(player's held item) is not 0:
					if canUsePower("LifeCircle::%uuid of player%") is true:
						if getEnergy(player's held item) > 4:
							blissSetcooldown("LifeCircle::%uuid of player%", toMilliseconds(3, 0), player)
							set {_num} to 2
						else if getEnergy(player's held item) is 4:
							blissSetcooldown("LifeCircle::%uuid of player%", toMilliseconds(3, 10), player)
							set {_num} to 2
						else if getEnergy(player's held item) is 3:
							blissSetcooldown("LifeCircle::%uuid of player%", toMilliseconds(3, 20), player)
							set {_num} to 2
						else if getEnergy(player's held item) is 2:
							blissSetcooldown("LifeCircle::%uuid of player%", toMilliseconds(3, 30), player)
							set {_num} to 1
						else if getEnergy(player's held item) is 1:
							blissSetcooldown("LifeCircle::%uuid of player%", toMilliseconds(3, 35), player)
							set {_num} to 1
						set {_h1} to player's max health
						add 5 to {_h1}
						set player's max health to {_h1}
						send "<##FE04B4>🔮 <##B8FFFB>You have activated &f💖<##FE04B4>Privilege Precinct &r&7(radius 3)" to player
						send "<##FE04B4>🔮 <##B8FFFB>You have recieved additional <##FE04B4>hearts <##B8FFFB>by <##FE04B4>%player%" to player
						set {_loc} to target entity of player's location
						loop {_num} + {_num} times:
							LifeCircleReal({_num}, {_loc})
							add 0.5 to {_num}
						LifeCircleRealLast({_num}, {_loc})
						loop all players within {_num} blocks of target entity of player:
							if loop-player is not player:
								if {lifeblessed::%loop-player's uuid%} is not set:
									if IsTrusted(player, loop-player) is true:
										send "<##FE04B4>🔮 <##B8FFFB>You have recieved additional <##FE04B4>hearts <##B8FFFB>by <##FE04B4>%player%" to loop-player
										set {_health} to loop-player's max health
										add 4 to {_health}
										set loop-player's max health to {_health}
										wait 90 seconds
										set loop-player's max health to 10
										delete {lifeblessed::%loop-player's uuid%}
						wait 90 seconds
						set player's max health to 10
				
