		remove 0.03 from {_superfkux}
	wait 1 tick

	loop 6 times:

		
		set {_fluxloc} to location {_fluxn} metres in front of {_loc}

		set {_pl} to {_fluxloc}
		set {_step} to 45 # Set a larger step value here
		set {_iterations} to 8
		add 5 to {_flusyesye}
