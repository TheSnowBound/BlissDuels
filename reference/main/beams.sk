function energyboom609(loc: location, p: player): # END ROD FOR 45-55% BEAM
	set {_fluxn} to 1
	set {_fluxloc} to {_loc}

	set {_superfkux} to 0.3
	set {_supervectoirvalue} to 0.3
	set {_flusyesye} to 20
	
