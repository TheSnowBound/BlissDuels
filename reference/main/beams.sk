		add 0.8 to {_fluxn}
		remove 0.01 from {_superfkux}
		loop all entities in radius 5 of {_fluxloc}: 
			if loop-entity is not {_p}:
				if loop-entity doesn't contain {_dontdmgagain::*}:
					if IsTrusted({_p}, loop-entity) is false:
						add loop-entity to {_dontdmgagain::*}
						set {-fluxKiller} to {_p}

						damage loop-entity by {fluxKineticDMG::%{_p}'s uuid%} percent of loop-entity's health
						set durability of loop-entity's helmet to durability of loop-entity's helmet - {-dura}
						set durability of loop-entity's chestplate to durability of loop-entity's helmet - {-dura}
						set durability of loop-entity's leggings to durability of loop-entity's helmet - {-dura}
						set durability of loop-entity's boots to durability of loop-entity's helmet - {-dura}
					else:
