function energyboom505(loc: location, p: player):
	set {_fluxn} to 1
	set {_fluxloc} to  {_loc}

	set {_superfkux} to 2.5
	loop 20 times:
		if {fluxShootingBeam.%{_p}'s uuid%} is true:

			set {_fluxloc} to location {_fluxn} metres in front of {_loc}

