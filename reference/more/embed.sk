function upgradeEmbed(p: player):
	create a new embed:
		title: "%{_p}%'s has upgraded their gem to tier 2"
		description: "`%{_p}% used upgrader`"
		color: "#ff0000"
		timestamp: true
		footer: {_footer}
		thumbnail: "https://static.wikia.nocookie.net/blisssmp/images/f/f8/Upgrader.webp/revision/latest?cb=20231230112313"
		author: {_author}
		fields: {_field}, {_field2}
		saveInto: {_embed}
	create a new webhook message:
		message: "Smp notification"
		webhook: "%{-webhook}%" 
		username: "SMP Leaks 🥶"
		avatar: "https://static.wikia.nocookie.net/blisssmp/images/3/39/Site-community-image/revision/latest?cb=20230524102827"
