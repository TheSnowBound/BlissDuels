on load:
	# Energy from None
	set {-Bliss.Fragment} to nautilus shell named "<##F878FF>ЙўбҙҮбҙҚ &r&7кң°КҖбҙҖЙўбҙҚбҙҮЙҙбҙӣ" with lore "&7 Only FOr Recipes" with custom model data 240
	set {-Bliss.Revive.3} to nautilus shell named "&dRestoration &fItem" with lore "&7Attempts: 3" with custom model data 210
	set {-Bliss.Revive.2} to nautilus shell named "&dRestoration &fItem" with lore "&7Attempts: 2" with custom model data 210
	set {-Bliss.Revive.1} to nautilus shell named "&dRestoration &fItem" with lore "&7Attempts: 1" with custom model data 210
	set {-Bliss.Revive.0} to nautilus shell named "&dRestoration &fItem" with lore "&7Attempts: 0 : Usless" with custom model data 210
	set {-Bliss.Repair.4} to nautilus shell named "&7&lКҖбҙҮбҙҳбҙҖЙӘКҖ бҙӢЙӘбҙӣ" with lore "&7 Player Capacity : &f 10 " with custom model data 200
	set {-menu} to globe banner pattern named "&7[&e&lвӯҗ&7] <##75FDFF>Remote <##FFCF75>Control" with custom model data 310	
	set {-lmaonum} to 0
	loop 61 times:
		set {-energyitem::none::%{-lmaonum}%} to a nautilus shell with custom model data 300 named "<##96FFD9>&lбҙҮЙҙбҙҮКҖЙўКҸ <##FFE4AB>ЙӘЙҙ бҙҖ КҷбҙҸбҙӣбҙӣКҹбҙҮ" named "<##96FFD9>&lбҙҮЙҙбҙҮКҖЙўКҸ <##FFE4AB>ЙӘЙҙ бҙҖ КҷбҙҸбҙӣбҙӣКҹбҙҮ" with lore "<##96FFD9>&lFrom: <##FFE4AB>None" and "&7Expires in: &f&l%{-lmaonum}% <##FFE4AB>minutes"
		add 1 to {-lmaonum}
	delete {-lmaonum}
	# Items


	set {-tradegui::life2::100} to a prismarine shard named "<##FE04B4>&lКҹЙӘТ“бҙҮ <##FFD773>ЙўбҙҮбҙҚ" with lore "&fChance: 100%%" with custom model data 4
	set {-tradegui::strength2::100} to a prismarine shard named "<##F10103>&lsбҙӣКҖбҙҮЙҙЙўбҙӣКң <##FFD773>ЙўбҙҮбҙҚ" with lore "&fChance: 100%%" with custom model data 10
	set {-tradegui::fire2::100} to a prismarine shard named "<##FE8120>&lТ“ЙӘКҖбҙҮ <##FFD773>ЙўбҙҮбҙҚ" with lore "&fChance: 100%%" with custom model data 2
	set {-tradegui::speed2::100} to a prismarine shard named "<##FEFD17>&lsбҙҳбҙҮбҙҮбҙ… <##FFD773>ЙўбҙҮбҙҚ" with lore "&fChance: 100%%" with custom model data 8
	set {-tradegui::wealth2::100} to a prismarine shard named "<##0EC912>&lбҙЎбҙҮбҙҖКҹбҙӣКң <##FFD773>ЙўбҙҮбҙҚ" with lore "&fChance: 100%%" with custom model data 12
