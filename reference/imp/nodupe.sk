import:
	java.time.Duration
	java.lang.System
	org.bukkit.Particle
	java.lang.String
	org.bukkit.inventory.PlayerInventory
	org.bukkit.Bukkit
	org.bukkit.event.player.PlayerInteractEntityEvent
	org.bukkit.event.player.PlayerInteractEvent
	org.bukkit.inventory.EquipmentSlot
	org.bukkit.event.inventory.InventoryClickEvent
	org.bukkit.Material

on right click:
	if {-trading::%player's uuid%} is true:
		cancel event

on inventory click:
	if player's open inventory = event-inventory:
		if any:
			click action is lmb
			click action is rmb
		then:
			if IsGem(player's cursor slot) is true:
				cancel event
		if click action is swap offhand:
			if IsGem(player's offhand item) is true:
				cancel event
		if click action is number key:
			if IsGem(player's inventory.getItem(event.getHotbarButton())) is true:
				cancel event
	if event-inventory = player's inventory:
		if any:
			click action is shift+lmb
			click action is shift+rmb
		then:
			if IsGem(event-item) is true:
				cancel event

on InventoryClickEvent:
	set {_clicked} to event.getCurrentItem()
	set {_cursor} to event.getCursor()

	if "%event.getCurrentItem()%" contains "bundle":
		if IsGem({_cursor}) is true:
			cancel event

on InventoryClickEvent:
	set {_clicked} to event.getCurrentItem()
	set {_cursor} to event.getCursor()

	if "%event.getCursor()%" contains "bundle":
		if IsGem({_clicked}) is true:
			cancel event

function noextraGems(p: player):
	loop all items in {_p}'s inventory where [IsGem(input) is true]:
		if {_gem} is set:
			set loop-item to air
			continue
		set {_gem} to loop-item

every 5 seconds:
	{-Options::MultipleGems} is false
	loop all players:
		noextraGems(loop-player)

on inventory drag:
	set {_slots::*} to event.getRawSlots()
	loop {_slots::*}:
		set {_slot} to "%loop-value%"
		replace all "[" with "" in {_slot}
		replace all "]" with "" in {_slot}
		set {_list::*} to split {_slot} at " "

	loop {_list::*}:
		set {_num} to loop-value parsed as integer
		if player's open inventory = event.getView().getInventory({_num}):
			if IsGem(past event-item) is true:
				cancel event

