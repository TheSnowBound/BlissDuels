on drop:
	if IsGem(event-item) is true:
		cancel event


on PlayerInteractEntityEvent:
	event.getRightClicked() is an item frame
	if event.getHand() is EquipmentSlot.HAND:
		IsGem(event.getPlayer()'s held item) is true
		event.setCancelled(true)

	if event.getHand() is EquipmentSlot.OFF_HAND:
		IsGem(event.getPlayer()'s off hand item) is true
		event.setCancelled(true)


on PlayerInteractEntityEvent:
	event.getRightClicked() is an allay
	if event.getHand() is EquipmentSlot.HAND:
		IsGem(event.getPlayer()'s held item) is true
		event.setCancelled(true)

	if event.getHand() is EquipmentSlot.OFF_HAND:
		IsGem(event.getPlayer()'s off hand item) is true
		event.setCancelled(true)

on PlayerInteractEvent:
	event.getClickedBlock() is a decorated pot
	if event.getHand() is EquipmentSlot.HAND:
		IsGem(event.getPlayer()'s held item) is true
		event.setCancelled(true)

	if event.getHand() is EquipmentSlot.OFF_HAND:
		IsGem(event.getPlayer()'s off hand item) is true
		event.setCancelled(true)


# DRAGON EGG AND MACE

on inventory drag:
	set {_slots::*} to event.getRawSlots()
	loop {_slots::*}:
		set {_slot} to "%loop-value%"
		replace all "[" with "" in {_slot}
		replace all "]" with "" in {_slot}
		set {_list::*} to split {_slot} at ", "

	loop {_list::*}:
		set {_num} to loop-value parsed as integer
		if player's open inventory = event.getView().getInventory({_num}):
			if past event-item is a dragon egg or a mace:
				cancel event

on inventory click:
	if player's open inventory = event-inventory:
		if any:
			click action is lmb
			click action is rmb
		then:
			if player's cursor slot is a dragon egg or a mace:
				cancel event
		if click action is swap offhand:
			if player's offhand item is a mace or a dragon egg:
				cancel event
		if click action is number key:
			if player's inventory.getItem(event.getHotbarButton()) is a dragon egg or a mace:
				cancel event
	if event-inventory = player's inventory:
		if any:
			click action is shift+lmb
			click action is shift+rmb
		then:
			if event-item is a mace or a dragon egg:
				cancel event


on inventory click:
	if any:
		click action is lmb
		click action is rmb
	then:
		if any:
			"%cursor slot of player%" contains "bundle"
			IsGem(cursor slot of player) is true
		then:
			if any:
				"%event-item%" contains "bundle"
				IsGem(event-item) is true
			then:
				cancel event
	


on inventory click:
	if {Prog1} is true:
		if player's open inventory = event-inventory:
			if any:
				click action is lmb
				click action is rmb
			then:
				if player's cursor slot is obsidian:
					cancel event
			if click action is swap offhand:
				if player's offhand item is obsidian:
					cancel event
			if click action is number key:
				if player's inventory.getItem(event.getHotbarButton()) is obsidian:
					cancel event
		if event-inventory = player's inventory:
			if any:
				click action is shift+lmb
				click action is shift+rmb
			then:
				if event-item is obsidian:
					cancel event