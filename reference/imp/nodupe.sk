on inventory click:
	IsGem(event-item) is true
	cursor slot of player is not air
	if player can't hold 1 water bucket:
		cancel event

on pickup arrow:
	set {_filled} to true
	loop 35 times:
		if slot (loop-number) of player's inventory is air:
			set {_filled} to false
			stop loop
	if {_filled} is true:
		cancel event


on pickup:
	IsGem(player's cursor slot) is true
	cancel event


